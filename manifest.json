{
  "manifest_version": 3,
  "name": "Informatics Submissions Analyzer",
  "version": "8.0",
  "description": "Автоматический расчёт результатов по контестам на informatics.msk.ru",
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://informatics.msk.ru/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Informatics Analyzer"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://informatics.msk.ru/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "informatics-analyzer@custom.dev",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}